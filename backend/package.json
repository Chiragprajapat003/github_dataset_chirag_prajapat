{
  "name": "github-dataset-api",
  "version": "1.0.0",
  "description": "RESTful API system for managing GitHub repository datasets",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "data:import": "node src/scripts/importData.js --import",
    "data:delete": "node src/scripts/importData.js --delete",
    "verify": "node src/scripts/verifyRoutes.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
